# =============================================================================
# Chatr Server — Environment Variables Template
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your own values in .env
#   3. NEVER commit .env — only this .env.example file goes to Git
# =============================================================================


# --------------------------
# Server
# --------------------------
PORT=5001
NODE_ENV=development


# --------------------------
# Database
# --------------------------
# Local (no Docker): mongodb://localhost:27017/chatapp
# Docker: overridden by docker-compose to: mongodb://mongodb:27017/chatapp
MONGO_DB_URI=mongodb://localhost:27017/chatapp


# --------------------------
# Redis
# --------------------------
# Local (no Docker): localhost
# Docker: overridden by docker-compose to service name "redis"
REDIS_HOST=localhost
REDIS_PORT=6379


# --------------------------
# Auth
# --------------------------
# Generate a secure key:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-secret-key-here


# --------------------------
# CORS
# --------------------------
# Dev: http://localhost:3000,http://localhost
# Prod: https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost
